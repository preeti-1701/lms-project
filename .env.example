# ==============================================================
# Coursify — Environment Variables
# ==============================================================
# Copy this file to `.env` (same folder as manage.py) and fill in
# your actual values. Never commit the real .env to git.
#
# To enable email OTP verification, set the two values below:
#   1. EMAIL_HOST_USER    — your Gmail address
#   2. EMAIL_HOST_PASSWORD — 16-char App Password from Google
#
# How to get an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if you haven't already
#   3. Go to https://myaccount.google.com/apppasswords
#   4. App name: "Coursify LMS" → Create
#   5. Copy the 16-character password (no spaces needed)
#
# If you don't set these, the app still works — OTP codes will be
# printed to the Django terminal instead of emailed.
# ==============================================================

EMAIL_HOST_USER=your.email@gmail.com
EMAIL_HOST_PASSWORD=yourapppasswordhere
